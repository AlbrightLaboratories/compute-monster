# compute-monster provisioning config — derived from the documented inventory (docs/01).
# Edit values here; every step script reads them. Safe to re-run.

# --- Identity ---
HOSTNAME_WANT="compute-monster"

# --- Self-heal source: box pulls latest provisioning from here on each run ---
REPO_URL="https://github.com/AlbrightLaboratories/compute-monster.git"
REPO_BRANCH="main"
REPO_DIR="/opt/compute-monster"

# --- GPU (docs/01) ---
# RTX 3060 Ti → NVIDIA proprietary driver. "auto" = ubuntu-drivers recommended.
NVIDIA_DRIVER="auto"          # or e.g. "nvidia-driver-570"
INSTALL_NVIDIA_CONTAINER_TOOLKIT="true"   # needed if the node runs GPU pods

# --- Storage (docs/01, docs/02) ---
# 1TB NVMe = boot (already the install target). 2TB Seagate = bulk data.
DATA_MOUNT="/data"
DATA_FS="ext4"
# Leave DATA_DISK empty to auto-pick the largest unmounted non-NVMe block device
# (the 2TB Seagate). Set explicitly (e.g. /dev/sda) to be safe.
DATA_DISK=""

# --- Networking / WOL (docs/02 = 1GbE RTL8111H, docs/07) ---
NIC=""                        # empty = auto-detect the primary wired interface
ENABLE_WOL="true"

# --- RGB (docs/09) — Lian Li UNI hub VID 0x0CF2 / PID 0xA102 ---
ENABLE_RGB_METEOR="true"
RGB_COLOR="255,0,0"           # red #FF0000 (the documented scheme)
RGB_TAIL="255,23,19"          # #DD1713 meteor tail tint
RGB_SPEED="25"                # matches L-Connect outer Meteor speed
RGB_BRIGHTNESS="100"
RGB_BACKGROUND_RED="24"       # dim red "inner ring" background (0 = off)

# --- Fan control (docs/09 StandardSpeed curve) ---
SETUP_FANCONTROL="true"       # installs lm-sensors; PWM mapping needs one manual pwmconfig pass

# --- Kubernetes (docs/05, docs/06) ---
SETUP_KUBE_PREREQS="true"
K8S_MINOR="1.31"              # MATCH THE CLUSTER before running
KUBELET_MAX_PODS="160"        # 3 retiring workers total 143 pods > default 110
